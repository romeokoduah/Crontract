// ============================================================
// PROCUREMENT
// ============================================================

model Vendor {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  name        String
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  address     String?
  taxId       String?  @map("tax_id")
  category    String?
  rating      Int?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  bills          Bill[]

  @@map("vendors")
}

model PurchaseRequisition {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  number      String
  title       String
  description String?  @db.Text
  status      PRStatus @default(DRAFT)
  priority    Priority @default(MEDIUM)
  requestedBy String   @map("requested_by") @db.Uuid
  neededBy    DateTime? @map("needed_by")
  lines       Json
  totalAmount Decimal  @db.Decimal(14, 2)
  currency    String   @default("GHS")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, number])
  @@map("purchase_requisitions")
}

enum PRStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CONVERTED
  CANCELLED
}

model PurchaseOrder {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  number      String
  vendorId    String   @map("vendor_id") @db.Uuid
  title       String
  status      POStatus @default(DRAFT)
  issueDate   DateTime @map("issue_date")
  deliveryDate DateTime? @map("delivery_date")
  lines       Json
  subtotal    Decimal  @db.Decimal(14, 2)
  tax         Decimal  @default(0) @db.Decimal(14, 2)
  total       Decimal  @db.Decimal(14, 2)
  currency    String   @default("GHS")
  notes       String?  @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vendor        Vendor          @relation(fields: [vendorId], references: [id])
  goodsReceipts GoodsReceipt[]
  bills         Bill[]

  @@unique([workspaceId, number])
  @@map("purchase_orders")
}

enum POStatus {
  DRAFT
  SUBMITTED
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  BILLED
  CANCELLED
}

model GoodsReceipt {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  purchaseOrderId String   @map("purchase_order_id") @db.Uuid
  number          String
  receivedDate    DateTime @map("received_date")
  receivedBy      String   @map("received_by") @db.Uuid
  lines           Json
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@unique([workspaceId, number])
  @@map("goods_receipts")
}

// ============================================================
// ASSETS
// ============================================================

model AssetCategory {
  id             String             @id @default(uuid()) @db.Uuid
  workspaceId    String             @map("workspace_id") @db.Uuid
  name           String
  depMethod      DepreciationMethod @default(STRAIGHT_LINE) @map("dep_method")
  usefulLifeYears Int               @map("useful_life_years")
  createdAt      DateTime           @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assets    Asset[]

  @@unique([workspaceId, name])
  @@map("asset_categories")
}

enum DepreciationMethod {
  STRAIGHT_LINE
  REDUCING_BALANCE
}

model Asset {
  id            String      @id @default(uuid()) @db.Uuid
  workspaceId   String      @map("workspace_id") @db.Uuid
  assetNumber   String      @map("asset_number")
  name          String
  description   String?
  categoryId    String      @map("category_id") @db.Uuid
  status        AssetStatus @default(ACTIVE)
  location      String?
  serialNumber  String?     @map("serial_number")
  purchaseDate  DateTime    @map("purchase_date")
  purchaseCost  Decimal     @db.Decimal(14, 2) @map("purchase_cost")
  currentValue  Decimal     @db.Decimal(14, 2) @map("current_value")
  assignedTo    String?     @map("assigned_to") @db.Uuid
  warrantyExpiry DateTime?  @map("warranty_expiry")
  notes         String?     @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  AssetCategory @relation(fields: [categoryId], references: [id])

  @@unique([workspaceId, assetNumber])
  @@map("assets")
}

enum AssetStatus {
  ACTIVE
  MAINTENANCE
  CHECKED_OUT
  RETIRED
  DISPOSED
}

// ============================================================
// HSE (Health, Safety & Environment)
// ============================================================

model Incident {
  id              String           @id @default(uuid()) @db.Uuid
  workspaceId     String           @map("workspace_id") @db.Uuid
  number          String
  title           String
  description     String           @db.Text
  incidentDate    DateTime         @map("incident_date")
  location        String
  severity        IncidentSeverity
  type            IncidentType
  status          IncidentStatus   @default(REPORTED)
  reportedBy      String           @map("reported_by") @db.Uuid
  investigator    String?          @db.Uuid
  rootCause       String?          @map("root_cause") @db.Text
  correctiveActions Json?          @map("corrective_actions")
  injuredPersons  Json?            @map("injured_persons")
  witnesses       String[]         @default([])
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, number])
  @@map("incidents")
}

enum IncidentSeverity {
  NEAR_MISS
  MINOR
  MODERATE
  MAJOR
  FATAL
}

enum IncidentType {
  INJURY
  PROPERTY_DAMAGE
  ENVIRONMENTAL
  NEAR_MISS
  VEHICLE
  FIRE
  CHEMICAL
  ELECTRICAL
  OTHER
}

enum IncidentStatus {
  REPORTED
  UNDER_INVESTIGATION
  CORRECTIVE_ACTIONS
  CLOSED
  REOPENED
}

