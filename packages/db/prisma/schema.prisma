enum PayrollGlLineType {
  WAGES_EXPENSE
  EMPLOYER_SSNIT_EXPENSE
  EMPLOYER_TIER2_EXPENSE
  SSNIT_PAYABLE
  PAYE_PAYABLE
  TIER2_PAYABLE
